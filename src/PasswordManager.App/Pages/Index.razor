@page "/"
@inject ApiClient ApiClient
@inject AuthState AuthState
@inject DeviceAuthService DeviceAuthService
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar

@if (!AuthState.IsAuthenticated)
{
    <MudPaper Class="pa-8 mx-auto login-card modern-surface" MaxWidth="MaxWidth.Small" Elevation="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" />
            <MudText Typo="Typo.h5">@((isCreatingAccount) ? "Criar conta" : "Acesse o cofre")</MudText>
        </MudStack>
        <MudText Typo="Typo.body2" Class="mb-4 text-muted">@((isCreatingAccount) ? "Cadastre seu usuário e ative autenticação do celular." : "Faça login para gerenciar suas senhas com segurança.")</MudText>

        <MudTextField Label="Usuário" @bind-Value="login.Username" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" Disabled="isLoggingIn" />
        <MudTextField Label="Senha" InputType="InputType.Password" @bind-Value="login.Password" Variant="Variant.Outlined" Class="mt-3" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" Disabled="isLoggingIn" />

        @if (isCreatingAccount)
        {
            <MudCheckBox @bind-Value="register.RequireMobileAuthentication" Label="Exigir autenticação do celular (digital ou facial)" Class="mt-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Register" Class="mt-4" FullWidth="true" StartIcon="@Icons.Material.Filled.PersonAdd" Loading="isRegistering" Disabled="isRegistering">@(isRegistering ? "Criando conta..." : "Criar conta")</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ToggleAccountMode" Class="mt-2" FullWidth="true" Disabled="isRegistering">Já tenho conta</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="PerformLogin" Class="mt-4" FullWidth="true" StartIcon="@Icons.Material.Filled.Login" Loading="isLoggingIn" Disabled="isLoggingIn">@(isLoggingIn ? "Entrando..." : "Entrar")</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="ToggleAccountMode" Class="mt-2" FullWidth="true" Disabled="isLoggingIn">Criar conta</MudButton>
        }

        @if (!string.IsNullOrWhiteSpace(loginError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@loginError</MudAlert>
        }
    </MudPaper>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-5 modern-surface" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Nova senha</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mb-4 text-muted">Crie e salve uma credencial com aparência profissional.</MudText>

                <MudTextField Label="Descrição" @bind-Value="form.Description" Variant="Variant.Outlined" Disabled="isSaving" />
                <MudTextField Label="Usuário/Login" @bind-Value="form.Username" Variant="Variant.Outlined" Class="mt-3" Disabled="isSaving" />
                <MudTextField Label="Senha" @bind-Value="form.Password" Variant="Variant.Outlined" Class="mt-3" Disabled="isSaving" />

                <MudStack Row="true" Spacing="2" Class="mt-4" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Outlined" OnClick="Generate" StartIcon="@Icons.Material.Filled.AutoFixHigh" Disabled="isGenerating || isSaving" Loading="isGenerating">@(isGenerating ? "Gerando..." : "Gerar automática")</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Save" StartIcon="@Icons.Material.Filled.Save" Disabled="isSaving || isGenerating" Loading="isSaving">@(isSaving ? "Salvando..." : "Salvar")</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => CopyPassword(form.Password))" StartIcon="@Icons.Material.Filled.ContentCopy" Disabled="isCopying || isSaving" Loading="isCopying">@(isCopying ? "Copiando..." : "Copiar senha")</MudButton>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(lastCreatedPassword))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                        Senha criada com sucesso: <strong>@lastCreatedPassword</strong>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Class="ml-2" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => CopyPassword(lastCreatedPassword))" Disabled="isCopying">
                            Copiar
                        </MudButton>
                    </MudAlert>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-4">

                <!-- Header com título + busca -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                    <MudText Typo="Typo.h6">Senhas Salvas</MudText>

                    <MudTextField T="string"
                                  Placeholder="Buscar..."
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  ValueChanged="OnSearch"
                                  Class="search-field"
                                  Dense="true" />
                </MudStack>

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3" Wrap="Wrap.Wrap">
                    <MudSelect T="SortOption" Label="Ordenar por" Value="selectedSort" ValueChanged="OnSortChanged" Variant="Variant.Outlined" Dense="true" Class="sort-field" Disabled="isReloading">
                        <MudSelectItem Value="SortOption.Recentes">Mais recentes</MudSelectItem>
                        <MudSelectItem Value="SortOption.Descricao">Descrição (A-Z)</MudSelectItem>
                        <MudSelectItem Value="SortOption.Usuario">Usuário (A-Z)</MudSelectItem>
                        <MudSelectItem Value="SortOption.Antigas">Mais antigas</MudSelectItem>
                    </MudSelect>

                    <MudSelect T="int" Label="Itens por página" Value="pageSize" ValueChanged="OnPageSizeChanged" Variant="Variant.Outlined" Dense="true" Class="page-size-field" Disabled="isReloading">
                        <MudSelectItem Value="5">5</MudSelectItem>
                        <MudSelectItem Value="10">10</MudSelectItem>
                        <MudSelectItem Value="20">20</MudSelectItem>
                    </MudSelect>
                </MudStack>

                @if (!pagedPasswords.Any())
                {
                    <MudText Typo="Typo.body2" Class="pa-4 text-center">
                        Nenhuma senha cadastrada ainda.
                    </MudText>
                }
                else
                {
                    <MudList T="PasswordEntry" Class="password-list">
                        @foreach (var password in pagedPasswords)
                        {
                            <MudListItem T="PasswordEntry" Value="@password" Class="password-list-item">
                                <MudPaper Class="pa-4 password-card" Elevation="0">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap" Spacing="2">
                                        <MudStack Spacing="0" Class="password-meta">
                                            <MudText Typo="Typo.body1" Class="fw-500">@password.Description</MudText>
                                            <MudText Typo="Typo.body2" Class="username-text">@FormatUsername(password.Username)</MudText>
                                            <MudText Typo="Typo.caption" Class="created-at-text">Criada em @password.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                        </MudStack>

                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudPaper Class="px-3 py-1 password-box" Elevation="0">
                                                <MudText Typo="Typo.body2" Class="password-text">
                                                    @DisplayPassword(password)
                                                </MudText>
                                            </MudPaper>

                                            <MudTooltip Text="Mostrar/Ocultar">
                                                <MudIconButton Icon="@GetVisibilityIcon(password.Id)"
                                                               Size="Size.Small"
                                                               OnClick="@(() => ToggleVisibility(password.Id))" />
                                            </MudTooltip>

                                            <MudTooltip Text="Copiar senha">
                                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(() => CopyPassword(password.Secret))"
                                                               Disabled="isCopying" />
                                            </MudTooltip>

                                            <MudTooltip Text="Excluir">
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Size="Size.Small"
                                                               Color="Color.Error"
                                                               OnClick="@(() => DeletePassword(password.Id))"
                                                               Disabled="deletingPasswordId == password.Id || isSaving" />
                                            </MudTooltip>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </MudListItem>
                        }
                    </MudList>

                    <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                        <MudPagination Count="@totalPages" Selected="@currentPage" SelectedChanged="OnPageChanged" />
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private readonly HashSet<Guid> visiblePasswordIds = [];

    private LoginRequest login = new();
    private RegisterUserRequest register = new();
    private string? loginError;
    private bool isCreatingAccount;

    private CreatePasswordRequest form = new();
    private List<PasswordEntry> passwords = [];
    private string? lastCreatedPassword;
    private bool isGenerating;
    private bool isSaving;
    private bool isCopying;
    private bool isLoggingIn;
    private bool isRegistering;
    private Guid? deletingPasswordId;
    private bool isReloading;

    private string _search = string.Empty;
    private int currentPage = 1;
    private int pageSize = 10;
    private SortOption selectedSort = SortOption.Recentes;

    private enum SortOption
    {
        Recentes,
        Antigas,
        Descricao,
        Usuario
    }

    private IEnumerable<PasswordEntry> filteredPasswords
    {
        get
        {
            var filtered = string.IsNullOrWhiteSpace(_search)
                ? passwords
                : passwords.Where(p =>
                    p.Description.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    p.Username.Contains(_search, StringComparison.OrdinalIgnoreCase));

            return selectedSort switch
            {
                SortOption.Descricao => filtered.OrderBy(p => p.Description),
                SortOption.Usuario => filtered.OrderBy(p => p.Username),
                SortOption.Antigas => filtered.OrderBy(p => p.CreatedAtUtc),
                _ => filtered.OrderByDescending(p => p.CreatedAtUtc)
            };
        }
    }

    private int totalPages => Math.Max(1, (int)Math.Ceiling(filteredPasswords.Count() / (double)pageSize));

    private IEnumerable<PasswordEntry> pagedPasswords => filteredPasswords
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private void OnSearch(string value)
    {
        _search = value;
        currentPage = 1;
    }

    private void OnSortChanged(SortOption option)
    {
        selectedSort = option;
        currentPage = 1;
    }

    private void OnPageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
    }

    private void OnPageChanged(int page)
    {
        currentPage = page;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.IsAuthenticated)
        {
            await Reload();
        }
    }

    private void ToggleAccountMode()
    {
        loginError = null;
        isCreatingAccount = !isCreatingAccount;
    }

    private async Task Register()
    {
        loginError = null;

        if (string.IsNullOrWhiteSpace(login.Username) || string.IsNullOrWhiteSpace(login.Password))
        {
            loginError = "Informe usuário e senha para criar a conta.";
            return;
        }

        try
        {
            isRegistering = true;
            register.Username = login.Username;
            register.Password = login.Password;

            var result = await ApiClient.RegisterAsync(register);
            if (!result.IsSuccess)
            {
                loginError = result.ErrorMessage;
                return;
            }

            Snackbar.Add("Conta criada com sucesso. Faça login para entrar.", Severity.Success);
            isCreatingAccount = false;
        }
        finally
        {
            isRegistering = false;
        }
    }

    private async Task PerformLogin()
    {
        loginError = null;

        if (string.IsNullOrWhiteSpace(login.Username) || string.IsNullOrWhiteSpace(login.Password))
        {
            loginError = "Informe usuário e senha para continuar.";
            return;
        }

        try
        {
            isLoggingIn = true;
            login.MobileAuthenticationConfirmed = false;

            var firstAttempt = await ApiClient.LoginAsync(login);
            if (firstAttempt.RequiresMobileAuthentication)
            {
                var biometricConfirmed = await DeviceAuthService.AuthenticateAsync();
                if (!biometricConfirmed)
                {
                    loginError = "Autenticação por digital ou facial não confirmada.";
                    return;
                }

                login.MobileAuthenticationConfirmed = true;
                var secondAttempt = await ApiClient.LoginAsync(login);
                if (!secondAttempt.IsSuccess)
                {
                    loginError = secondAttempt.ErrorMessage ?? "Não foi possível validar seu acesso.";
                    return;
                }
            }
            else if (!firstAttempt.IsSuccess)
            {
                loginError = firstAttempt.ErrorMessage;
                return;
            }

            await Reload();
        }
        catch (Exception ex)
        {
            loginError = $"Não foi possível realizar login agora. Tente novamente em instantes.{ex}";
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    private async Task Generate()
    {
        try
        {
            isGenerating = true;
            var generated = await ApiClient.GeneratePasswordAsync(new GeneratePasswordRequest());
            form = form with { Password = generated };
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task DeletePassword(Guid id)
    {
        try
        {
            deletingPasswordId = id;
            await ApiClient.DeletePasswordAsync(id);
            await Reload();
            Snackbar.Add("Senha excluída com sucesso.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Não foi possível excluir a senha.", Severity.Error);
        }
        finally
        {
            deletingPasswordId = null;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Description) || string.IsNullOrWhiteSpace(form.Username))
        {
            Snackbar.Add("Informe descrição e usuário para salvar.", Severity.Warning);
            return;
        }

        try
        {
            isSaving = true;
            var created = await ApiClient.CreatePasswordAsync(form);
            lastCreatedPassword = created?.Secret;
            form = new CreatePasswordRequest();
            await Reload();
            Snackbar.Add("Senha salva com sucesso.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Não foi possível salvar a senha.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CopyPassword(string? password)
    {
        if (string.IsNullOrWhiteSpace(password))
        {
            return;
        }

        try
        {
            isCopying = true;
            await JsRuntime.InvokeVoidAsync("appClipboard.copyText", password);
        }
        finally
        {
            isCopying = false;
        }
    }

    private void ToggleVisibility(Guid passwordId)
    {
        if (!visiblePasswordIds.Add(passwordId))
        {
            visiblePasswordIds.Remove(passwordId);
        }
    }


    private static string FormatUsername(string? username)
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            return "Usuário não informado";
        }

        return username.Trim();
    }

    private string DisplayPassword(PasswordEntry entry) => visiblePasswordIds.Contains(entry.Id)
        ? entry.Secret
        : "••••••••";

    private string GetVisibilityIcon(Guid passwordId) => visiblePasswordIds.Contains(passwordId)
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private async Task Reload()
    {
        try
        {
            isReloading = true;
            passwords = (await ApiClient.GetPasswordsAsync()).OrderByDescending(x => x.CreatedAtUtc).ToList();
            currentPage = 1;
        }
        finally
        {
            isReloading = false;
        }
    }
}
